# Salin file ini menjadi ".env" lalu isi dengan kredensial Anda sendiri.
# JANGAN commit file ".env" (sudah ada di .gitignore).

# --- SMTP untuk mengirim kode OTP verifikasi email (real, bukan simulasi) ---
# Contoh menggunakan Gmail. Wajib pakai App Password (bukan password akun biasa):
# 1. Aktifkan 2-Step Verification: https://myaccount.google.com/security
# 2. Buat App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=akun_anda@gmail.com
SMTP_PASSWORD=isi_16_karakter_app_password

# --- Konfigurasi server TCP internal (biasanya tidak perlu diubah) ---
CHAT_HOST_INTERNAL=127.0.0.1
CHAT_PORT=5050
